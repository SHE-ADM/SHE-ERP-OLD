  object cad_cli: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    AfterOpen = cad_cliAfterOpen
    SQL.Strings = (
      
        'SELECT ID,CLI_FANT,CLI_RAZA,CLI_CNPJ,CLI_INSC,CLI_CPF,CLI_RG ,CL' +
        'I_CCM,CLI_MAIL,CLI_RICM,CLI_CICM,CLI_DDD,CLI_TEL1,CLI_CONT,'
      
        '          CLI_TLOG,CLI_LOGR,CLI_NUME,CLI_COMP,CLI_CEP ,CLI_BAI ,' +
        'CLI_CID ,CLI_ESTA,CLI_CMUN,CLI_DPAG,'
      
