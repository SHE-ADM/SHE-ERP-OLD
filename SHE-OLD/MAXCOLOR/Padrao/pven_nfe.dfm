  object psq_for: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    SQL.Strings = (
      
        'SELECT CAD_FOR.ID,FOR_FANT,FOR_RAZA,FOR_CNPJ,FOR_CPF,FOR_CRED,FO' +
        'R_CID,FOR_BAI,FOR_TLOG,FOR_LOGR,FOR_NUME,FOR_CEP,FOR_COMP,FOR_ES' +
        'TA,FOR_STA,FOR_STAV,FOR_DPAG,'
      
        '       FOR_VDSC,FOR_DCAD,FOR_DFUN,FOR_DALT,FOR_DULT,FOR_VULT,FOR' +
        '_DDD,FOR_TEL1,REP_FANT,USU_DUSU,FOR_STPD,FOR_DTRA,FOR_DUSU,'
      
        '       TRIM(CAST(SUBSTRING(FOR_OBSO FROM 1 FOR 512) AS VARCHAR(5' +
        '12))) FOR_OBSO'
      'FROM   CAD_FOR'
      'LEFT   OUTER JOIN CAD_USU ON CAD_FOR.FOR_CVEN = CAD_USU.USU_CUSU'
      'LEFT   OUTER JOIN CAD_REP ON CAD_FOR.FOR_CREP = CAD_REP.ID'
      'WHERE  CAD_FOR.ID = 0')
