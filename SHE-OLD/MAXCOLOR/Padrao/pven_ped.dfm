  object rom_cab: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    AutoCalcFields = False
    SQL.Strings = (
      
        'SELECT   ROM_CAB.*,CAD_CLI.CLI_FANT,CAD_USU.USU_DUSU,CAD_REP.REP' +
        '_FANT,PAG_DPAG'
      'FROM     CAD_CLI,CAD_USU,CAD_REP,TAB_PAG,ROM_CAB'
      'WHERE    ROM_CAB.ROM_CCLI = CAD_CLI.ID'
      'AND      ROM_CAB.ROM_CVEN = CAD_USU.USU_CUSU'
      'AND      ROM_CAB.ROM_CREP = CAD_REP.ID'
      'AND      ROM_CAB.ROM_CPAG = TAB_PAG.ID'
      'AND      ROM_CAB.ID       = 0'
      'ORDER BY ROM_CAB.ID DESC')
