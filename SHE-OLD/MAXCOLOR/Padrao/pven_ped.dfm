  object ped_prg_ite: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    AutoCalcFields = False
    SQL.Strings = (
      
        'SELECT    PED_PRG_ITE.*,CAD_PRO.ID,CAD_PRO.PRO_CART,CAD_PRO.PRO_' +
        'CPRO,CAD_PRO.PRO_CCOR,'
      
        '          CAD_PRO.PRO_RCOR,CAD_PRO.PRO_DCOR,CAD_PRO.PRO_DUNI,CAD' +
        '_PRO.PRO_PIPI,'
      
        '          CAD_PRO.PRO_CBAR,CAD_PRO.PRO_PPRO,CAD_PRO.PRO_CEMB,CAD' +
        '_PRO.PRO_GRAD,CAD_PRO.PRO_REPR,CAD_PRO.PRO_APRO,'
      '          CAD_PRO_IMG.PRO_FOTO'
      'FROM      PED_PRG_ITE "PED_PRG_ITE",CAD_PRO,CAD_PRO_IMG'
      'WHERE     PED_PRG_ITE.ROM_CPRO = CAD_PRO.ID'
      'AND       CAD_PRO.PRO_CART = CAD_PRO_IMG.PRO_CART'
      'AND       PED_PRG_ITE.ROM_CCAB = :ID'
      'ORDER  BY PED_PRG_ITE.ROM_ITEM')
