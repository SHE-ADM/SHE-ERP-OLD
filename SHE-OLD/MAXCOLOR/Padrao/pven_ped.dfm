  object Edicao: TIBDataSet
    Database = dmDADOS.bSHEILD
    Transaction = tSHEILD
    AfterDelete = EdicaoAfterDelete
    AfterInsert = EdicaoAfterInsert
    AfterPost = EdicaoAfterPost
    BeforeCancel = EdicaoBeforeCancel
    BeforeDelete = EdicaoBeforeDelete
    BeforeInsert = EdicaoBeforeInsert
    BeforePost = EdicaoBeforePost
    OnNewRecord = EdicaoNewRecord
    DeleteSQL.Strings = (
      'delete from PED_VEN_ITE'
      'where'
      '  ID = :OLD_ID')
    InsertSQL.Strings = (
      'insert into PED_VEN_ITE'
      
        '  (ID, ROM_ABCD, ROM_APRC, ROM_CART, ROM_CBAR, ROM_CCAB, ROM_CCL' +
        'F, ROM_CCO2, '
      
        '   ROM_CCOR, ROM_CDET, ROM_CDNF, ROM_CDOC, ROM_CDPD, ROM_CDPR, R' +
        'OM_CDRO, '
      
        '   ROM_CFOR, ROM_CGRD, ROM_CPR2, ROM_CPRO, ROM_CSEP, ROM_CUST, R' +
        'OM_DCO2, '
      
        '   ROM_DCOR, ROM_DERO, ROM_DGRD, ROM_DPRO, ROM_DSEP, ROM_DUNI, R' +
        'OM_FLAG, '
      
        '   ROM_FOTO, ROM_IPR2, ROM_IPRO, ROM_ITEM, ROM_LDSC, ROM_METR, R' +
        'OM_OBSE, '
      
        '   ROM_PCO2, ROM_PCOM, ROM_PCOR, ROM_PEMB, ROM_PESO, ROM_PIPI, R' +
        'OM_PPRO, '
      
        '   ROM_PRCA, ROM_PREC, ROM_PRPA, ROM_PSBR, ROM_PSCN, ROM_PSLQ, R' +
        'OM_PSMR, '
      
        '   ROM_QDIS, ROM_QTDE, ROM_QTPD, ROM_QTRL, ROM_QTSP, ROM_RCO2, R' +
        'OM_RCOR, '
      
        '   ROM_REND, ROM_RLDI, ROM_RLPD, ROM_RLSP, ROM_RPRC, ROM_RPRO, R' +
        'OM_STFI, '
      
        '   ROM_TOTA, ROM_TPRC, ROM_TSDE, ROM_UNIT, ROM_VBCIPI, ROM_VDSC,' +
        ' ROM_VIPI, '
      '   ROM_VPRC, ROM_VPRO)'
      'values'
      
        '  (:ID, :ROM_ABCD, :ROM_APRC, :ROM_CART, :ROM_CBAR, :ROM_CCAB, :' +
        'ROM_CCLF, '
      
        '   :ROM_CCO2, :ROM_CCOR, :ROM_CDET, :ROM_CDNF, :ROM_CDOC, :ROM_C' +
        'DPD, :ROM_CDPR, '
      
        '   :ROM_CDRO, :ROM_CFOR, :ROM_CGRD, :ROM_CPR2, :ROM_CPRO, :ROM_C' +
        'SEP, :ROM_CUST, '
      
        '   :ROM_DCO2, :ROM_DCOR, :ROM_DERO, :ROM_DGRD, :ROM_DPRO, :ROM_D' +
        'SEP, :ROM_DUNI, '
      
        '   :ROM_FLAG, :ROM_FOTO, :ROM_IPR2, :ROM_IPRO, :ROM_ITEM, :ROM_L' +
        'DSC, :ROM_METR, '
      
        '   :ROM_OBSE, :ROM_PCO2, :ROM_PCOM, :ROM_PCOR, :ROM_PEMB, :ROM_P' +
        'ESO, :ROM_PIPI, '
      
        '   :ROM_PPRO, :ROM_PRCA, :ROM_PREC, :ROM_PRPA, :ROM_PSBR, :ROM_P' +
        'SCN, :ROM_PSLQ, '
      
        '   :ROM_PSMR, :ROM_QDIS, :ROM_QTDE, :ROM_QTPD, :ROM_QTRL, :ROM_Q' +
        'TSP, :ROM_RCO2, '
      
        '   :ROM_RCOR, :ROM_REND, :ROM_RLDI, :ROM_RLPD, :ROM_RLSP, :ROM_R' +
        'PRC, :ROM_RPRO, '
      
        '   :ROM_STFI, :ROM_TOTA, :ROM_TPRC, :ROM_TSDE, :ROM_UNIT, :ROM_V' +
        'BCIPI, '
      '   :ROM_VDSC, :ROM_VIPI, :ROM_VPRC, :ROM_VPRO)')
    RefreshSQL.Strings = (
      'Select '
      '  ID,'
      '  ROM_CCAB,'
      '  ROM_CDOC,'
      '  ROM_CDPR,'
      '  ROM_CDPD,'
      '  ROM_CDRO,'
      '  ROM_CDNF,'
      '  ROM_ITEM,'
      '  ROM_CART,'
      '  ROM_IPRO,'
      '  ROM_CPRO,'
      '  ROM_IPR2,'
      '  ROM_CPR2,'
      '  ROM_DPRO,'
      '  ROM_CCOR,'
      '  ROM_RCOR,'
      '  ROM_DCOR,'
      '  ROM_PCOR,'
      '  ROM_CCO2,'
      '  ROM_RCO2,'
      '  ROM_DCO2,'
      '  ROM_PCO2,'
      '  ROM_CGRD,'
      '  ROM_DGRD,'
      '  ROM_DUNI,'
      '  ROM_QTDE,'
      '  ROM_QTRL,'
      '  ROM_QTSP,'
      '  ROM_RLSP,'
      '  ROM_QTPD,'
      '  ROM_RLPD,'
      '  ROM_QDIS,'
      '  ROM_RLDI,'
      '  ROM_PRCA,'
      '  ROM_PRPA,'
