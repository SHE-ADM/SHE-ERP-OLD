  object PED_HST: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    AfterScroll = PED_HSTAfterScroll
    BeforeOpen = PED_HSTBeforeOpen
    SQL.Strings = (
      'SELECT FIRST 500'
      
        '       PK.ID AS IDPK,FK.ID AS IDFK,PK.ROM_DERO AS DEPK,PK.ROM_DR' +
        'OM AS DTPK,'
      
        '       FK.ROM_UNIT AS VPRC_COM,FK.ROM_QTDE AS QTDE,FK.ROM_DUNI A' +
        'S UCOM,'
      
        '       CP.PRO_CPRO AS SKU,FK.ROM_DPRO AS DECP,FK.ROM_DCOR AS DGC' +
        'P'
      ''
      'FROM   PED_VEN_CAB AS PK'
      'JOIN   PED_VEN_ITE AS FK ON (FK.ROM_CCAB = PK.ID)'
      'JOIN   CAD_PRO     AS CP ON (CP.ID       = FK.ROM_CPRO)'
      'WHERE  PK.ROM_CCLI = 1'
      ''
      'ORDER BY PK.ID DESC')
    Left = 712
    Top = 48
    object PED_HSTIDPK: TIntegerField
      FieldName = 'IDPK'
      Origin = '"PED_VEN_CAB"."ID"'
      Required = True
    end
    object PED_HSTIDFK: TIntegerField
      FieldName = 'IDFK'
      Origin = '"PED_VEN_ITE"."ID"'
      Required = True
    end
    object PED_HSTDEPK: TIBStringField
      DisplayLabel = 'Pedido'
      FieldName = 'DEPK'
      Origin = '"PED_VEN_CAB"."ROM_DERO"'
      Size = 30
    end
    object PED_HSTDTPK: TDateField
      DisplayLabel = 'Emiss'#227'o'
      FieldName = 'DTPK'
      Origin = '"PED_VEN_CAB"."ROM_DROM"'
      DisplayFormat = 'dd.mm.yy'
    end
    object PED_HSTVPRC_COM: TFloatField
      DisplayLabel = 'Pre'#231'o'
      FieldName = 'VPRC_COM'
      Origin = '"PED_VEN_ITE"."ROM_UNIT"'
      DisplayFormat = ',##,0.00'
    end
    object PED_HSTQTDE: TIBBCDField
      DisplayLabel = 'Quant.'
      FieldName = 'QTDE'
      Origin = '"PED_VEN_ITE"."ROM_QTDE"'
      DisplayFormat = ',##,0.##'
      Precision = 18
      Size = 4
    end
    object PED_HSTUCOM: TIBStringField
      DisplayLabel = 'UN'
      FieldName = 'UCOM'
      Origin = '"PED_VEN_ITE"."ROM_DUNI"'
      Size = 3
    end
    object PED_HSTSKU: TIBStringField
      FieldName = 'SKU'
      Origin = '"CAD_PRO"."PRO_CPRO"'
    end
    object PED_HSTDECP: TIBStringField
      DisplayLabel = 'Descri'#231#227'o'
      FieldName = 'DECP'
      Origin = '"PED_VEN_ITE"."ROM_DPRO"'
      Size = 120
    end
    object PED_HSTDGCP: TIBStringField
      DisplayLabel = 'Grade'
      FieldName = 'DGCP'
      Origin = '"PED_VEN_ITE"."ROM_DCOR"'
      Size = 30
    end
