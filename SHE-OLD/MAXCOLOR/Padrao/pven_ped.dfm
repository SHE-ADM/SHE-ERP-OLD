  object cli_sta: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    SQL.Strings = (
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_BAN_BAI'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_BAN_BAI_002'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_BAN_BAI_003'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_BAN_BAI_004'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_BAN_BAI_005'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_BAN_BAI_006'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_CAR_BAI'
      'WHERE  FIN_STFI = :FIN_STFI'
      'AND    FIN_CCLI = :FIN_CCLI'
      'UNION'
      'SELECT FIN_DOCT,FIN_DVEN,FIN_VALO FROM FIN_REC_CAR_BAI_002'
