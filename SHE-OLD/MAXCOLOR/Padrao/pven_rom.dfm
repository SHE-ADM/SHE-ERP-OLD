  object rom_002: TIBQuery
    Database = dmDADOS.bSHEILD
    Transaction = tSHEILD
    BufferChunks = 2500
    SQL.Strings = (
      
        'SELECT   ROM_CDRO,ROM_IPRO,ROM_IPR2,ROM_DCOR,ROM_PCOR,ROM_DCO2,R' +
        'OM_PCO2,ROM_DPRO,ROM_DUNI,ROM_TPRC,ROM_ABCD,ROM_METR,ROM_PESO,RO' +
        'M_PSCN,ROM_DSEP,'
      
        '         ROM_PSMR,ROM_REND,ROM_OBSE,SUM(ROM_QTPD) "ROM_QTDE",AVG' +
        '(ROM_VDSC) "ROM_VDSC",AVG(ROM_PREC) "ROM_PREC",AVG(ROM_UNIT) "RO' +
        'M_UNIT"'
      'FROM     ROM_ITE'
      'WHERE ROM_FLAG = '#39'1'#39
      
        'GROUP BY ROM_CDRO,ROM_IPRO,ROM_IPR2,ROM_DCOR,ROM_PCOR,ROM_DCO2,R' +
        'OM_PCO2,ROM_DPRO,ROM_DUNI,ROM_TPRC,ROM_ABCD,ROM_METR,ROM_PESO,RO' +
        'M_PSCN,ROM_DSEP,'
      '         ROM_PSMR,ROM_REND,ROM_OBSE')
    Left = 792
    Top = 96
