        '   ROM_DPRO, ROM_DSEP, ROM_DUNI, ROM_FLAG, ROM_FOTO, ROM_IPR2, R' +
        'OM_IPRO, '
      
        '   ROM_ITEM, ROM_LDSC, ROM_METR, ROM_OBSE, ROM_PCO2, ROM_PCOM, R' +
        'OM_PCOR, '
      
        '   ROM_PEMB, ROM_PESO, ROM_PIPI, ROM_PPRO, ROM_PRCA, ROM_PREC, R' +
