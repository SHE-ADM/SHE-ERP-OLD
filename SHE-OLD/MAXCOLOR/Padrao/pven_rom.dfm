  object psq_ite: TIBQuery
    Database = dmDADOS.ibDB
    Transaction = IBTra
    BufferChunks = 2500
    SQL.Strings = (
      
        'SELECT PED_VEN_ITE.*,CAD_PRO.PRO_CART,PRO_CPRO,PRO_DPR2,PRO_DPR3' +
        ',PRO_DPR4,PRO_DPR5,PRO_PPRO,PRO_METR,PRO_PESO,PRO_REND,PRO_PSCN,' +
        'PRO_PSMR,PRO_CBAR,PRO_FOTO,PRO_PIPI'
      'FROM   PED_VEN_ITE,CAD_PRO,CAD_PRO_IMG'
      'WHERE  PED_VEN_ITE.ROM_CPRO = CAD_PRO.ID'
      'AND    CAD_PRO.PRO_CART     = CAD_PRO_IMG.PRO_CART'
