    InsertSQL.Strings = (
      'insert into CAD_CLI_CRD'
      '  (ID, IDCL, IDEP, VCRD)'
      'values'
      '  (:ID, :IDCL, :IDEP, :VCRD)')
    RefreshSQL.Strings = (
      'Select '
      '  ID,'
      '  IDEP,'
      '  IDCL,'
      '  VCRD'
      'from CAD_CLI_CRD '
      'where'
      '  ID = :ID')
    SelectSQL.Strings = (
      'SELECT   ID,IDEP,IDCL,VCRD FROM CAD_CLI_CRD'
      'ORDER BY ID')
    ModifySQL.Strings = (
      'update CAD_CLI_CRD'
      'set'
      '  ID = :ID,'
      '  IDCL = :IDCL,'
