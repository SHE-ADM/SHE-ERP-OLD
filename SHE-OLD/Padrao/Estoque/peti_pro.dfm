  object ped_ven_cab: TIBQuery
    Tag = 1
    Database = FBird.DBERP
    Transaction = IBTra
    SQL.Strings = (
      'SELECT PK.ID,PK.DEPD,CAST(PK.DTCA AS DATE) AS DTPD,PK.CTNR,'
      '       PK.CDRO,PK.CDNF,PK.CDBX,'
      
        '       PK.IDCD,CD.CLI_FANT AS DECD,PK.IDCV,CV.LOGIN AS DECV,PK.I' +
        'DCR,CR.REP_FANT AS DECR,'
      '       PK.QTDE,PK.QTSP,PK.TCDE,'
      
        '       PK.CDPD,PK.STPD,PK.FAPD,TP.PED_EST_QTSP AS SEPD,PK.CDCO,P' +
        'K.STCO,PK.TPCO,PK.RECO,PK.CDPG,PK.CDST,PK.REST,PK.DEST,'
      '       PK.INFADPED'
      'FROM   PED_VEN_CAB AS PK'
      'JOIN   CAD_CLI     AS CD ON (CD.ID = PK.IDCD)'
      'JOIN   TAB_USER    AS CV ON (CV.ID = PK.IDCV)'
      'JOIN   CAD_REP     AS CR ON (CR.ID = PK.IDCR)'
      'JOIN   TAB_TPO     AS TP ON (TP.ID = PK.CDPD)'
      'WHERE  PK.ID = 0')
    Left = 440
    Top = 464
    object ped_ven_cabID: TIntegerField
      FieldName = 'ID'
      Origin = '"PED_VEN_CAB"."ID"'
      ProviderFlags = [pfInUpdate, pfInWhere, pfInKey]
